# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/tonmirror"

# App URL (used in TON Connect manifest)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_TONCONNECT_MANIFEST_URL="http://localhost:3000/tonconnect-manifest.json"

# Telegram
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME="your_bot_username"

# TON webhook (live source only)
TON_WEBHOOK_SECRET="change_me_to_random_secret"
TON_API_KEY=""

# Feature flags (default: demo mode on, live source off)
NEXT_PUBLIC_ENABLE_DEMO_MODE="true"
NEXT_PUBLIC_ENABLE_LIVE_SOURCE="false"
